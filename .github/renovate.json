{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": false,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "commitMessagePrefix": "ci:"
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "commitMessagePrefix": "build(docker):"
    },
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchPackageNames": ["ivenos/avxs"],
      "enabled": false
    },
    {
      "matchPackageNames": ["rust"],
      "groupName": "Rust toolchain"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["ARG SVT_AV1_VERSION=(?<currentValue>[^\\n]+)"],
      "datasourceTemplate": "gitlab-releases",
      "depNameTemplate": "AOMediaCodec/SVT-AV1",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["ARG SVT_AV1_HDR_REF=(?<currentDigest>[^\\n]+)"],
      "currentValueTemplate": "main",
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "https://github.com/juliobbv-p/svt-av1-hdr"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["ARG FFMS2_VERSION=(?<currentValue>[^\\n]+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "FFMS/ffms2",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["ARG VSHIP_VERSION=(?<currentValue>[^\\n]+)"],
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "https://codeberg.org/Line-fr/Vship",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["ARG RUST_VERSION=(?<currentValue>[^\\n]+)"],
      "datasourceTemplate": "docker",
      "depNameTemplate": "rust",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/appimage\\.yml$/"],
      "matchStrings": ["SVT_AV1_VERSION:\\s*\"?(?<currentValue>[^\"\\s]+)\"?"],
      "datasourceTemplate": "gitlab-releases",
      "depNameTemplate": "AOMediaCodec/SVT-AV1",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/appimage\\.yml$/"],
      "matchStrings": ["SVT_AV1_HDR_REF:\\s*\"?(?<currentDigest>[^\"\\s]+)\"?"],
      "currentValueTemplate": "main",
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "https://github.com/juliobbv-p/svt-av1-hdr"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/appimage\\.yml$/"],
      "matchStrings": ["FFMS2_VERSION:\\s*\"?(?<currentValue>[^\"\\s]+)\"?"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "FFMS/ffms2",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/appimage\\.yml$/"],
      "matchStrings": ["VSHIP_VERSION:\\s*\"?(?<currentValue>[^\"\\s]+)\"?"],
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "https://codeberg.org/Line-fr/Vship",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/appimage\\.yml$/"],
      "matchStrings": ["RUST_VERSION:\\s*\"?(?<currentValue>[^\"\\s]+)\"?"],
      "datasourceTemplate": "docker",
      "depNameTemplate": "rust",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)README\\.md$/"],
      "matchStrings": ["badge/svt--av1-(?<currentValue>v[0-9][^-]+)-purple"],
      "datasourceTemplate": "gitlab-releases",
      "depNameTemplate": "AOMediaCodec/SVT-AV1",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)README\\.md$/"],
      "matchStrings": ["badge/svt--av1--hdr-[0-9a-f]+-purple\\)\\]\\(https://github\\.com/juliobbv-p/svt-av1-hdr\\) <!-- renovate: juliobbv-p/svt-av1-hdr@(?<currentDigest>[0-9a-f]+) -->"],
      "currentValueTemplate": "main",
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "https://github.com/juliobbv-p/svt-av1-hdr",
      "autoReplaceStringTemplate": "badge/svt--av1--hdr-{{{replace '^(.{7}).*' '$1' newDigest}}}-purple)](https://github.com/juliobbv-p/svt-av1-hdr) <!-- renovate: juliobbv-p/svt-av1-hdr@{{{newDigest}}} -->"
    }
  ]
}
