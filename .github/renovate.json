{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": false,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "commitMessagePrefix": "ci:"
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "commitMessagePrefix": "build(docker):"
    },
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchPackageNames": ["ivenos/avxs"],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["ARG SVT_AV1_VERSION=(?<currentValue>[^\\n]+)"],
      "datasourceTemplate": "gitlab-releases",
      "depNameTemplate": "AOMediaCodec/SVT-AV1",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["ARG SVT_AV1_HDR_REF=(?<currentDigest>[^\\n]+)"],
      "currentValueTemplate": "main",
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "https://github.com/juliobbv-p/svt-av1-hdr"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["ARG FFMS2_VERSION=(?<currentValue>[^\\n]+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "FFMS/ffms2",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["ARG VMAF_VERSION=(?<currentValue>[^\\n]+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "Netflix/vmaf",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["ARG RUST_VERSION=(?<currentValue>[^\\n]+)"],
      "datasourceTemplate": "docker",
      "depNameTemplate": "rust",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/appimage\\.yml$/"],
      "matchStrings": ["SVT_AV1_VERSION:\\s*\"?(?<currentValue>[^\"\\s]+)\"?"],
      "datasourceTemplate": "gitlab-releases",
      "depNameTemplate": "AOMediaCodec/SVT-AV1",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/appimage\\.yml$/"],
      "matchStrings": ["SVT_AV1_HDR_REF:\\s*\"?(?<currentDigest>[^\"\\s]+)\"?"],
      "currentValueTemplate": "main",
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "https://github.com/juliobbv-p/svt-av1-hdr"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/appimage\\.yml$/"],
      "matchStrings": ["FFMS2_VERSION:\\s*\"?(?<currentValue>[^\"\\s]+)\"?"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "FFMS/ffms2",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/appimage\\.yml$/"],
      "matchStrings": ["VMAF_VERSION:\\s*\"?(?<currentValue>[^\"\\s]+)\"?"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "Netflix/vmaf",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/appimage\\.yml$/"],
      "matchStrings": ["RUST_VERSION:\\s*\"?(?<currentValue>[^\"\\s]+)\"?"],
      "datasourceTemplate": "docker",
      "depNameTemplate": "rust",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Cargo\\.toml$/"],
      "matchStrings": ["rust-version\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "docker",
      "depNameTemplate": "rust",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)README\\.md$/"],
      "matchStrings": ["\\[(?<currentValue>v[0-9][^\\]]*)\\]\\(https://gitlab\\.com/AOMediaCodec/SVT-AV1\\)"],
      "datasourceTemplate": "gitlab-releases",
      "depNameTemplate": "AOMediaCodec/SVT-AV1",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)README\\.md$/"],
      "matchStrings": ["\\[[0-9a-f]+\\]\\(https://github\\.com/juliobbv-p/svt-av1-hdr/commit/(?<currentDigest>[0-9a-f]+)\\)"],
      "currentValueTemplate": "main",
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "https://github.com/juliobbv-p/svt-av1-hdr",
      "autoReplaceStringTemplate": "[{{{replace '^(.{7}).*' '$1' newDigest}}}](https://github.com/juliobbv-p/svt-av1-hdr/commit/{{{newDigest}}})"
    }
  ]
}
