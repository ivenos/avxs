{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "automerge": true
    },
    {
      "enabled": false,
      "matchPackageNames": ["ghcr.io/ivenos/avxs"]
    }
  ],
  "regexManagers": [
    {
      "fileMatch": ["Dockerfile"],
      "matchStrings": [
        "ARG SVT_AV1_VERSION=(?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "gitlab-releases",
      "depNameTemplate": "AOMediaCodec/SVT-AV1",
      "versioningTemplate": "semver"
    },
    {
      "fileMatch": ["Dockerfile"],
      "matchStrings": [
        "ARG SVT_AV1_HDR_VERSION=(?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "juliobbv-p/svt-av1-hdr",
      "versioningTemplate": "semver"
    },
    {
      "fileMatch": ["Dockerfile"],
      "matchStrings": [
        "ARG FFMS2_VERSION=(?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "FFMS/ffms2",
      "versioningTemplate": "loose"
    },
    {
      "fileMatch": ["Dockerfile"],
      "matchStrings": [
        "ARG RUST_VERSION=(?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "rust",
      "versioningTemplate": "semver"
    }
  ]
}
